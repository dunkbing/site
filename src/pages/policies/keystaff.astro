---
import Layout from "../../layouts/Layout.astro";
---

<Layout title="KeyStaff App Privacy Policy">
  <div class="max-w-2xl mx-auto p-6 text-gray-800">
    <h1 class="text-3xl font-bold text-blue-600 mb-4">
      KeyStaff App Privacy Policy
    </h1>
    <p class="mb-4">
      We don't collect, store, or share any personal data. The app runs entirely
      on your device, and every practice session stays with you.
    </p>
  </div>
</Layout>
